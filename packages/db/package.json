{
  "name": "@math-item-os/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./client.ts"
  },
  "scripts": {
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:seed": "dotenv -e ../../.env -- tsx seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6",
    "prisma": "^6"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.19.0"
  }
}
