# === Database ===
# PostgreSQL 연결 URL (Prisma용, 커넥션 풀링 포함)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mathitem?schema=public"
# PostgreSQL 직접 연결 URL (마이그레이션용, 커넥션 풀링 미사용)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/mathitem"

# === Redis ===
# Redis 캐시 및 세션 저장소 URL
REDIS_URL="redis://localhost:6379"

# === Meilisearch ===
# Meilisearch 검색 엔진 호스트
MEILISEARCH_HOST="http://localhost:7700"
# Meilisearch 마스터 키 (운영 환경에서는 반드시 변경)
MEILISEARCH_MASTER_KEY="change-me-master-key"

# === Auth (Auth.js v5) ===
# 세션 암호화 키 (생성: openssl rand -base64 32)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# 인증 콜백 기본 URL
AUTH_URL="http://localhost:3000"
# Google OAuth 클라이언트 ID
AUTH_GOOGLE_ID="your-google-client-id"
# Google OAuth 클라이언트 시크릿
AUTH_GOOGLE_SECRET="your-google-client-secret"

# === Math AI Service ===
# 수학 AI 마이크로서비스 URL (SymPy 기반)
MATH_AI_SERVICE_URL="http://localhost:8000"

# === Application ===
# 로그 레벨 (debug | info | warn | error)
LOG_LEVEL="debug"
# 실행 환경 (development | production | test)
NODE_ENV="development"

# === Judge0 CE (코드 실행) ===
# Judge0 CE API 서버 URL (docker-compose로 실행 시 기본값)
JUDGE0_API_URL="http://localhost:2358"
